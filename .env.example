# Shamsu — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string (Neon or any Postgres host). Used by Prisma for
# both migrations (via prisma.config.ts) and the runtime client (via the Neon
# driver adapter in src/lib/db.ts).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign and verify JWT session tokens (auth). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="replace-with-a-long-random-string"

# Anthropic API key for the Claude classifier (variable/output detection,
# replay_mode classification). If unset, the rule-based fallback runs instead
# — the API maker still works, just without Claude's reasoning.
ANTHROPIC_API_KEY="sk-ant-api03-..."

# 32-byte hex key used for AES-256 encryption of stored credentials
# (credentials_vault table). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-a-64-char-hex-string"

# The real bKash personal/merchant number buyers should send payment to
# (PRD section 4.3: manual bKash confirmation). NEXT_PUBLIC_ so the billing
# page can render it — never hardcode a real number in source.
NEXT_PUBLIC_BKASH_NUMBER="01XXXXXXXXX"

# Public origin used to build confirmed-API endpoint URLs (e.g.
# https://api.shamsu.example). Falls back to the request's own origin if
# unset, which is fine for local dev but should be set explicitly in
# production so generated endpoint URLs are stable behind a proxy/CDN.
PUBLIC_URL="https://your-domain.example"
